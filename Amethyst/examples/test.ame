// Rolling test file. Feel free to edit when testing forks. Any changes to this file in a PR will likely be accepted.

namespace example;

entitydef minecraft:base {
    bool Invulnerable;
    string CustomName;
    unsafe_string[] Tags;
}

entitydef test_entity implements minecraft:base {
    float Health;
}

class Node {
    int x;

    Node(int x) {
        this.x = x;
    }
}

Node[] nodes = [];
int idex = 0;

#tick
void tick() {
    nodes.add(new Node(++idex));

    if (nodes.size() > 100) {
        nodes.remove_at(0);
    }

    print(amethyst:gc/heap_info.size());
}

