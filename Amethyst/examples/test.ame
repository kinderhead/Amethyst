class Node {
    int x;

    Node(int x) {
        this.x = x;
    }
}

class List {
    Node[] arr;

    void print() {
        for (int i = 0; i < this.arr.size(); ++i) {
            print(this.arr[i]);
        }
    }
}

List save;

#load
void main() {
    save = new List();
    save = null;

    @/say $(save)

    //amethyst:exit();
}
