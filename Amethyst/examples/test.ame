namespace example;

entitydef minecraft:base {
    bool Invulnerable;
    string CustomName;
    unsafe_string[] Tags;
}

entitydef test_entity implements minecraft:base {
    float Health;
}

class Test {
    int x;

    Test(int val) {
        this.x = val;
    }

    virtual void foo() {
        print(this.x);
    }
}

class Test2 implements Test {
    int y;

    Test2(int val1, int val2) : Test(val1) {
        this.y = val2;
    }

    virtual void foo() {
        print(this.x, " ", this.y);
    }
}

#load
