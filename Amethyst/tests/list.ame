namespace test;

struct list_tester {
    int x;
    int y;
}

#test
void test_int_list_add() {
    start("int list add");

    int[] x;
    int y = 6;

    x.add(10);
    x.add(y);
    x.add(y * 2);

    assert_eq(x[0], 10);
    assert_eq(x[1], 6);
    assert_eq(x[2], 12);
    assert_eq(x.size(), 3);
    
    complete();
}

#test
void test_int_list_index() {
    start("int list index");

    int[] x;
    int y = 6;

    x.add(10);
    x.add(y);
    x.add(y * 2);

    int i = 0;
    assert_eq(x[i], 10);

    i = i + 1;
    assert_eq(x[i], 6);

    i = i + 1;
    assert_eq(x[i], 12);
    
    complete();
}

#test
void test_int_list_literal() {
    start("int list literal");

    int y = 6;
    int[] x = [10, y, y * 2, 7];

    assert_eq(x[0], 10);
    assert_eq(x[1], 6);
    assert_eq(x[2], 12);
    assert_eq(x[3], 7);
    assert_eq(x.size(), 4);
    
    complete();
}

#test
void test_int_list_ref() {
    start("int list ref");

    int[][] arr;
    arr.add([1,2,5]);
    arr[0].add(7);

    int i = 0;
    arr[i].add(-90);

    assert_eq(arr[0][0], 1);
    assert_eq(arr[0][1], 2);
    assert_eq(arr[0][2], 5);
    assert_eq(arr[0][3], 7);
    assert_eq(arr[0][4], -90);
    
    complete();
}

#test
void test_list_where() {
    start("list where");

    list_tester[] l = [];
    l.add((list_tester){x: 1, y: 1});
    l.add((list_tester){x: 1, y: 2});
    l.add((list_tester){x: 2, y: 3});

    var subset = l.where({x: 1});

    assert_eq(subset.size(), 2);
    assert_eq(subset[0].x, 1);
    assert_eq(subset[0].y, 1);
    assert_eq(subset[1].x, 1);
    assert_eq(subset[1].y, 2);
    
    complete();
}

#test
void test_list_all() {
    start("list all");

    list_tester[] l = [];
    l.add((list_tester){x: 1, y: 1});
    l.add((list_tester){x: 1, y: 2});
    l.add((list_tester){x: 2, y: 3});

    l.all().x = 7;

    assert_eq(l[0].x, 7);
    assert_eq(l[0].y, 1);
    assert_eq(l[1].x, 7);
    assert_eq(l[1].y, 2);
    assert_eq(l[2].x, 7);
    assert_eq(l[2].y, 3);
    
    complete();
}

#test
void test_int_list_pop() {
    start("int list pop");

    int[] x = [1, 2, 3, 4, 5];

    assert_eq(x.pop(), 5);
    assert_eq(x.pop(), 4);
    assert_eq(x.pop(), 3);
    assert_eq(x.pop(), 2);
    assert_eq(x.pop(), 1);
    assert_eq(x.size(), 0);
    
    complete();
}
